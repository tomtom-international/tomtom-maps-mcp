{
  "name": "@tomtom-org/tomtom-mcp",
  "version": "1.1.16",
  "description": "MCP server integrating TomTom APIs",
  "packageManager": "pnpm@10.28.2",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    "import": "./dist/index.esm.js",
    "require": "./dist/index.cjs.js"
  },
  "bin": {
    "tomtom-mcp": "./bin/tomtom-mcp.js",
    "tomtom-mcp-http": "./bin/tomtom-mcp-http.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build:ts": "NODE_OPTIONS='--max-old-space-size=8192' tsc --emitDeclarationOnly --declaration --declarationMap",
    "build:rollup": "rollup -c",
    "build": "pnpm run build:ts && pnpm run build:rollup",
    "build:bin": "shx chmod +x bin/tomtom-mcp.js && shx chmod +x bin/tomtom-mcp-http.js",
    "start": "node dist/index.esm.js",
    "start:http": "node dist/indexHttp.esm.js",
    "dev": "cross-env NODE_OPTIONS=\"--no-warnings --loader ts-node/esm\" node src/index.ts",
    "dev:http": "cross-env NODE_OPTIONS=\"--no-warnings --loader ts-node/esm\" node src/indexHttp.ts",
    "prepare": "pnpm run build",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:comprehensive": "node tests/test-comprehensive.js",
    "test:all": "pnpm run test && pnpm run test:comprehensive",
    "lint": "biome lint src",
    "lint:fix": "biome check --write src",
    "format": "biome format src",
    "format:fix": "biome format --write src",
    "check": "biome check src",
    "check:fix": "biome check --write --unsafe src",
    "publish:npm": "pnpm publish --access restricted",
    "clean": "shx rm -rf dist coverage",
    "prebuild": "pnpm run clean && node scripts/generate-version.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "axios": "^1.13.4",
    "canvas": "^3.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.0",
    "rollup": "^4.57.1",
    "shx": "^0.4.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.32",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@maplibre/maplibre-gl-native": "^6.3.0",
    "@rollup/rollup-linux-x64-gnu": "4.9.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomtom-international/tomtom-mcp.git"
  },
  "homepage": "https://github.com/tomtom-international/tomtom-mcp",
  "bugs": {
    "url": "https://github.com/tomtom-international/tomtom-mcp/issues"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "keywords": [
    "tomtom",
    "mcp",
    "navigation",
    "maps",
    "routing",
    "geocoding",
    "cross-platform"
  ],
  "overrides": {
    "body-parser": "^2.2.1",
    "inflight": "npm:lru-cache@^11.1.0",
    "qs": "^6.14.1"
  }
}
