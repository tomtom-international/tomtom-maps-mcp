# TomTom API key - required
# Get your key from https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key_here

# Maps API selection (default: TomTom Maps/standard TomTom APIs)
# Set to "tomtom-orbis-maps" to use TomTom Orbis Maps APIs, otherwise TomTom Maps is used
# MAPS=tomtom-orbis-maps

# Port for the HTTP server (default: 3000)
PORT=3000

# Log level (default: info)
# Available levels: debug, info, warn, error
# Use "debug" for local development to see all logs
LOG_LEVEL=debug

# Public origin and path of the MCP endpoint (used for OAuth resource identifier)
# MCP_BASE_URL=https://mcp.tomtom.com
# MCP_BASE_URL_PATH=/maps

# CIAM (External ID / B2C) tenant — issues JWTs at https://{id}.ciamlogin.com/{id}/v2.0
# Required to enable OAuth on the server.
# CIAM_TENANT_ID=
# CIAM_DOMAIN=

# Workforce (B2B) Entra tenant — optional. When set, the server also accepts
# JWTs issued at https://login.microsoftonline.com/{id}/v2.0 so internal employees
# signing in directly against the corporate tenant are authorized too.
# WORKFORCE_TENANT_ID=
